&PROJWFC
  prefix    = 'pwscf'           ! must match the completed NSCF run
  outdir    = './out'
  filpdos   = 'pwscf.pdos'      ! output filename prefix
  Emin      = -20.0             ! min energy relative to Fermi level (eV)
  Emax      =  10.0             ! max energy relative to Fermi level (eV)
  DeltaE    =  0.01             ! energy step (eV)
  ngauss    = 0                 ! 0 = Gaussian broadening
  degauss   = 0.02              ! broadening width (Ry)
/
! Run with: projwfc.x < projwfc.in > projwfc.out
! Output: pwscf.pdos_atm#N(Element)_wfc#M(l) files for each atom/orbital
