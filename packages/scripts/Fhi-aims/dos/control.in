#==============================================================
# FHI-aims control.in — Density of states (DOS) template
# Run AFTER a converged SCF calculation.
# Use a denser k-grid than SCF for accurate DOS.
# Functional: GGA-PBE | Basis: tight
#==============================================================

xc                 pbe
relativistic       atomic_zora regular
spin               none

# Denser k-grid for DOS accuracy (typically 2–3× the SCF grid)
k_grid             12 12 12

sc_accuracy_rho    1e-5
sc_accuracy_eev    1e-3
sc_accuracy_etot   1e-6
sc_iter_limit      200

mixer              pulay
n_max_pulay        10
charge_mix_param   0.2

# --- Total DOS ---
# Syntax: output dos  E_min  E_max  n_points  broadening(eV)
# Energies are relative to the Fermi level.
output             dos  -20.0  10.0  3000  0.05

# --- Atom-projected (partial) DOS ---
output             atom_proj_dos  -20.0  10.0  3000  0.05

# --- Species-projected DOS (angular-momentum resolved) ---
# output           species_proj_dos  -20.0  10.0  3000  0.05

################################################################################
# Append species blocks from $AIMS_HOME/species_defaults/tight/
################################################################################
