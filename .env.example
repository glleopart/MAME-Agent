# ============================================================
# MAME — MAterials for ME
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Provider ---
# Option A: Anthropic (recommended)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Option B: OpenCode GO (alternative, OpenAI-compatible)
# OPENAI_API_KEY=your_opencode_go_key_here
# OPENAI_BASE_URL=https://opencode.ai/api/v1

# --- Materials Project ---
MP_API_KEY=your_materials_project_key_here

# --- App Settings ---
MAME_LANGUAGE=en
